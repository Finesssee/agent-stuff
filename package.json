{
  "name": "mitsupi",
  "version": "1.5.0",
  "description": "Armin's pi coding agent commands, skills, extensions, and themes",
  "repository": {
    "type": "git",
    "url": "https://github.com/mitsuhiko/agent-stuff.git"
  },
  "readme": "README.md",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-theme"
  ],
  "pi": {
    "extensions": [
      "./pi-extensions/answer.ts",
      "./pi-extensions/behavior-modes.ts",
      "./pi-extensions/btw.ts",
      "./pi-extensions/context.ts",
      "./pi-extensions/control.ts",
      "./pi-extensions/files.ts",
      "./pi-extensions/go-to-bed.ts",
      "./pi-extensions/loop.ts",
      "./pi-extensions/notify.ts",
      "./pi-extensions/precise-edit.ts",
      "./pi-extensions/prompt-editor.ts",
      "./pi-extensions/review.ts",
      "./pi-extensions/session-breakdown.ts",
      "./pi-extensions/todos.ts",
      "./pi-extensions/uv.ts",
      "./pi-extensions/whimsical.ts"
    ],
    "skills": [
      "./skills"
    ],
    "themes": [
      "./pi-themes"
    ],
    "prompts": [
      "./commands"
    ]
  },
  "dependencies": {
    "diff": "^8.0.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*"
  }
}
